<?xml version="1.0" ?>
<ruleset
    name="Custom Ruleset"
    xmlns="http://pmd.sf.net/ruleset/1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
>
    <!-- Exclude stubs, which are empty classes and functions defined for PHPStan -->
    <exclude-pattern>stubs/*</exclude-pattern>

    <!-- Exclude unit test files -->
    <exclude-pattern>tests/*</exclude-pattern>

    <!-- Exclude other directories -->
    <exclude-pattern>bower_components/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>var/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="rulesets/cleancode.xml">
        <!-- Avoiding else expresssions does not help -->
        <exclude name="ElseExpression" />

        <!-- Calling static functions is necessary sometimes -->
        <exclude name="StaticAccess" />

        <!-- Replaced with PHP Linter -->
        <exclude name="BooleanArgumentFlag" />
    </rule>
    <rule ref="rulesets/design.xml">
        <!-- Replaced with PHP Linter -->
        <exclude name="DevelopmentCodeFragment" />
    </rule>
    <rule ref="rulesets/naming.xml">
        <!-- Replaced with PHP Linter -->
        <exclude name="ConstantNamingConventions" />
        <exclude name="LongClassName" />
        <exclude name="LongVariable" />
        <exclude name="ShortClassName" />
        <exclude name="ShortMethodName" />
        <exclude name="ShortVariable" />
    </rule>
    <rule ref="rulesets/unusedcode.xml" />
</ruleset>
