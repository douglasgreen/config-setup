{
    "name": "douglasgreen/config-setup",
    "description": "Preconfigured setup files for linting, fixing, and testing PHP and JavaScript projects",
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/douglasgreen/config-setup",
    "authors": [
        {
            "name": "Douglas Green",
            "email": "douglas@nurd.site",
            "homepage": "https://nurd.site/",
            "role": "Developer"
        }
    ],
    "keywords": [
        "automation",
        "ci-cd",
        "code-quality",
        "coding-standards",
        "composer",
        "config",
        "fixing",
        "linting",
        "php",
        "phpcs",
        "php-cs-fixer",
        "phpunit",
        "static-analysis",
        "testing"
    ],
    "autoload": {
        "psr-4": {
            "DouglasGreen\\ConfigSetup\\": "src/"
        }
    },
    "bin": [
        "bin/config_setup.php"
    ],
    "require": {
        "php": ">=8.1",
        "nette/neon": "^3.4"
    },
    "require-dev": {
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.11",
        "rector/rector": "^1.1",
        "symplify/easy-coding-standard": "^12.3"
    },
    "scripts": {
        "lint": [
            "ecs",
            "phpstan analyse",
            "phpmd --cache --cache-file var/cache/phpmd/cache.php . text phpmd.xml",
            "rector --dry-run"
        ],
        "lint:fix": [
            "ecs --fix",
            "rector"
        ]
    }
}
