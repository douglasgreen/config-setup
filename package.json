{
    "name": "douglasgreen/config-setup",
    "description": "Preconfigured setup files for linting, fixing, and testing PHP and JavaScript projects",
    "license": "MIT",
    "engines": {
        "node": ">=18",
        "npm": ">=9"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.3",
        "@commitlint/config-conventional": "^19.2",
        "@prettier/plugin-php": "^0.22",
        "@prettier/plugin-xml": "^3.4",
        "eslint": "^8.57",
        "eslint-config-airbnb-base": "^15.0",
        "eslint-config-standard": "^17.1",
        "eslint-plugin-import": "^2.29",
        "eslint-plugin-n": "^16.6",
        "eslint-plugin-promise": "^6.2",
        "husky": "^9.0",
        "mocha": "^10.2",
        "prettier": "^3.3",
        "prettier-plugin-sh": "^0.14",
        "stylelint": "^16.6",
        "stylelint-config-standard": "^36.0"
    },
    "scripts": {
        "commitlint": "commitlint --edit",
        "lint": "eslint . && stylelint '**/*.css'",
        "lint:fix": "eslint --fix . && prettier --write .",
        "prepare": "husky"
    }
}
